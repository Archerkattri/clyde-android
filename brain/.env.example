# Copy to brain/.env and keep secret. CLYDE_KEY must match the app's X-Clyde-Key.
# Generate once:  node -e "console.log('CLYDE_KEY='+require('crypto').randomBytes(16).toString('hex'))"
CLYDE_KEY=replace-with-32-hex-characters

# Optional overrides (defaults shown):
# BRAIN_HOST=127.0.0.1
# BRAIN_PORT=8765
# APP_HOST=127.0.0.1
# APP_PORT=8766
# RISH_CMD=rish
# SU_CMD=su
# CLYDE_MODEL=            # leave blank to use the account default model

# DO NOT set ANTHROPIC_API_KEY. The brain refuses to start if it is present —
# it would silently switch billing from your subscription to pay-per-token.
