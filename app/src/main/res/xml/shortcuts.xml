<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Long-press the Clyde icon → "Settings": opens the control center instead of the popup
         (MainActivity reads ACTION_HOME and skips the summon-popup fast path). -->
    <shortcut
        android:shortcutId="clyde-settings"
        android:enabled="true"
        android:icon="@drawable/ic_clyde_logo"
        android:shortcutShortLabel="@string/shortcut_settings_short"
        android:shortcutLongLabel="@string/shortcut_settings_long">
        <intent
            android:action="dev.kris.clyde.action.HOME"
            android:targetPackage="dev.kris.clyde"
            android:targetClass="dev.kris.clyde.MainActivity" />
    </shortcut>
</shortcuts>
